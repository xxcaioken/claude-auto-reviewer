# claude-auto-reviewer — variáveis de ambiente opcionais
#
# Todas têm default sensato. Descomente APENAS pra customizar.
# Como usar:  cp .env.example .env  &&  set -a; source .env; set +a

# === Paths ===

# Diretório onde state.db, logs/, repos.txt e o lockfile ficam.
# Default: ~/.claude/heartbeat
# HEARTBEAT_DIR=

# Path do binário claude.
# Default: detectado por `which claude`, fallback ~/.local/bin/claude
# CLAUDE_BIN=

# Path do binário gh (GitHub CLI).
# Default: detectado por `which gh`, fallback /usr/bin/gh
# GH_BIN=

# Diretório de trabalho onde claude é invocado.
# Importante: deve ser um diretório SEM `.claude/commands/code-review.md` local
# (senão o comando do projeto vence o global).
# Default: $HOME
# CLAUDE_CWD=

# === Comportamento ===

# Marcador HTML que identifica comentários do bot. NÃO mude depois de PRs já
# terem comentários — você "perderia" os antigos no fetch_bot_comments.
# Default: <!-- code-review-bot:v1 -->
# MARKER=

# Label do GitHub que sinaliza pular revisão num PR específico.
# Default: skip-code-review
# SKIP_LABEL=

# === Timeouts (segundos) ===

# Limite por revisão de claude (mata o processo se ultrapassar).
# Default: 600 (10min)
# CLAUDE_TIMEOUT=

# Limite por chamada gh.
# Default: 60
# GH_TIMEOUT=

# Timeout do sqlite3.connect (espera lock).
# Default: 30
# SQLITE_TIMEOUT=
